{
  "expo": {
    "name": "FocusPix",
    "slug": "focuspix",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "focuspix",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.focuspix.app"
    },
    "android": {
      "package": "com.focuspix.app",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "FocusPix needs access to your photos to show them in your gallery.",
          "savePhotosPermission": "FocusPix needs access to save photos to your library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-video",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0b0c",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e04a8b1-323c-4866-b7e1-4a38439f4cfe"
      }
    },
    "owner": "modelminds"
  }
}
